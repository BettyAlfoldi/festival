# Auto detect text files and perform LF normalization
* text=auto

html
<!DOCTYPE html>
<html lang="cs">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Psí Kafe | Kavárna pro lidi a jejich parťáky</title>
  <meta name="description" content="Útulná psí kavárna s výběrovou kávou, domácími dezerty a dobrotami pro čtyřnohé návštěvníky.">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=Fredoka:wght@600;700&display=swap" rel="stylesheet">

  <style>
    :root {
      --cream: #fffaf1;
      --white: #ffffff;
      --brown: #51362d;
      --brown-dark: #30201b;
      --orange: #ed835f;
      --orange-dark: #d96945;
      --yellow: #f4c95d;
      --green: #8fab78;
      --text: #4f433e;
      --muted: #766963;
      --border: rgba(81, 54, 45, 0.12);
      --shadow: 0 20px 50px rgba(81, 54, 45, 0.12);
      --radius: 24px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    html {
      scroll-behavior: smooth;
      scroll-padding-top: 90px;
    }

    body {
      font-family: "DM Sans", sans-serif;
      color: var(--text);
      background: var(--cream);
      line-height: 1.6;
      overflow-x: hidden;
    }

    img {
      display: block;
      width: 100%;
    }

    a {
      color: inherit;
      text-decoration: none;
    }

    button,
    input,
    select,
    textarea {
      font: inherit;
    }

    button {
      cursor: pointer;
    }

    h1, h2, h3, .logo {
      font-family: "Fredoka", sans-serif;
      color: var(--brown-dark);
      line-height: 1.1;
    }

    .container {
      width: min(1160px, calc(100% - 40px));
      margin-inline: auto;
    }

    .section {
      padding: 100px 0;
    }

    .section-heading {
      max-width: 680px;
      margin-bottom: 48px;
    }

    .section-heading.center {
      text-align: center;
      margin-inline: auto;
    }

    .eyebrow {
      display: inline-block;
      margin-bottom: 12px;
      color: var(--orange-dark);
      font-size: 0.82rem;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
    }

    .section-heading h2 {
      margin-bottom: 16px;
      font-size: clamp(2rem, 5vw, 3.4rem);
    }

    .section-heading p {
      color: var(--muted);
      font-size: 1.06rem;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 9px;
      min-height: 52px;
      padding: 0 24px;
      border: 2px solid transparent;
      border-radius: 999px;
      font-weight: 700;
      transition: 0.2s ease;
    }

    .btn-primary {
      color: white;
      background: var(--orange);
      box-shadow: 0 10px 25px rgba(237, 131, 95, 0.3);
    }

    .btn-primary:hover {
      background: var(--orange-dark);
      transform: translateY(-2px);
    }

    .btn-secondary {
      color: var(--brown);
      background: white;
      border-color: var(--border);
    }

    .btn-secondary:hover {
      border-color: var(--orange);
      transform: translateY(-2px);
    }

    /* Navigace */
    .header {
      position: sticky;
      top: 0;
      z-index: 1000;
      background: rgba(255, 250, 241, 0.9);
      border-bottom: 1px solid var(--border);
      backdrop-filter: blur(14px);
    }

    .nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: 78px;
    }

    .logo {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 1.45rem;
    }

    .logo-mark {
      display: grid;
      place-items: center;
      width: 43px;
      height: 43px;
      color: white;
      background: var(--orange);
      border-radius: 14px;
      transform: rotate(-4deg);
    }

    .nav-links {
      display: flex;
      align-items: center;
      gap: 30px;
      list-style: none;
    }

    .nav-links a:not(.btn) {
      position: relative;
      font-weight: 600;
    }

    .nav-links a:not(.btn)::after {
      content: "";
      position: absolute;
      left: 0;
      bottom: -6px;
      width: 0;
      height: 2px;
      background: var(--orange);
      transition: width 0.2s ease;
    }

    .nav-links a:not(.btn):hover::after {
      width: 100%;
    }

    .menu-button {
      display: none;
      width: 46px;
      height: 46px;
      color: var(--brown);
      background: white;
      border: 1px solid var(--border);
      border-radius: 14px;
      font-size: 1.4rem;
    }

    /* Hero */
    .hero {
      position: relative;
      min-height: calc(100vh - 78px);
      display: flex;
      align-items: center;
      padding: 70px 0 90px;
      isolation: isolate;
    }

    .hero::before,
    .hero::after {
      content: "";
      position: absolute;
      z-index: -1;
      border-radius: 50%;
      filter: blur(2px);
    }

    .hero::before {
      top: 8%;
      left: -180px;
      width: 360px;
      height: 360px;
      background: rgba(244, 201, 93, 0.24);
    }

    .hero::after {
      right: -180px;
      bottom: 0;
      width: 440px;
      height: 440px;
      background: rgba(143, 171, 120, 0.17);
    }

    .hero-grid {
      display: grid;
      grid-template-columns: 1.02fr 0.98fr;
      align-items: center;
      gap: 70px;
    }

    .hero-badge {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-bottom: 22px;
      padding: 9px 15px;
      color: var(--brown);
      background: rgba(244, 201, 93, 0.28);
      border: 1px solid rgba(244, 201, 93, 0.55);
      border-radius: 999px;
      font-size: 0.9rem;
      font-weight: 700;
    }

    .hero h1 {
      max-width: 680px;
      margin-bottom: 22px;
      font-size: clamp(3.2rem, 7vw, 6.2rem);
      letter-spacing: -0.04em;
    }

    .hero h1 span {
      color: var(--orange);
    }

    .hero-copy {
      max-width: 600px;
      margin-bottom: 30px;
      color: var(--muted);
      font-size: 1.15rem;
    }

    .hero-actions {
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
    }

    .hero-note {
      display: flex;
      flex-wrap: wrap;
      gap: 22px;
      margin-top: 34px;
      color: var(--muted);
      font-size: 0.92rem;
      font-weight: 600;
    }

    .hero-note span::before {
      content: "✓";
      margin-right: 7px;
      color: var(--green);
      font-weight: 800;
    }

    .hero-visual {
      position: relative;
    }

    .hero-image {
      aspect-ratio: 4 / 5;
      object-fit: cover;
      border: 10px solid white;
      border-radius: 42% 42% 28% 28%;
      box-shadow: var(--shadow);
    }

    .floating-card {
      position: absolute;
      display: flex;
      align-items: center;
      gap: 12px;
      max-width: 230px;
      padding: 16px 18px;
      background: rgba(255, 255, 255, 0.95);
      border: 1px solid var(--border);
      border-radius: 18px;
      box-shadow: var(--shadow);
      backdrop-filter: blur(10px);
    }

    .floating-card strong {
      display: block;
      color: var(--brown-dark);
    }

    .floating-card small {
      color: var(--muted);
    }

    .floating-card.one {
      top: 10%;
      left: -45px;
    }

    .floating-card.two {
      right: -25px;
      bottom: 12%;
    }

    .floating-icon {
      display: grid;
      flex: 0 0 45px;
      place-items: center;
      height: 45px;
      background: var(--cream);
      border-radius: 14px;
      font-size: 1.4rem;
    }

    /* Statistiky */
    .stats {
      padding: 0 0 70px;
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      overflow: hidden;
      background: var(--brown);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
    }

    .stat {
      padding: 30px 20px;
      color: rgba(255,255,255,.72);
      text-align: center;
      border-right: 1px solid rgba(255,255,255,.13);
    }

    .stat:last-child {
      border-right: 0;
    }

    .stat strong {
      display: block;
      margin-bottom: 2px;
      color: white;
      font-family: "Fredoka", sans-serif;
      font-size: 2rem;
    }

    /* O nás */
    .about {
      background: white;
    }

    .about-grid {
      display: grid;
      grid-template-columns: 0.9fr 1.1fr;
      align-items: center;
      gap: 80px;
    }

    .about-images {
      position: relative;
      min-height: 580px;
    }

    .about-main {
      width: 82%;
      height: 520px;
      object-fit: cover;
      border-radius: 32px;
      box-shadow: var(--shadow);
    }

    .about-small {
      position: absolute;
      right: 0;
      bottom: 0;
      width: 48%;
      height: 245px;
      object-fit: cover;
      border: 8px solid white;
      border-radius: 28px;
      box-shadow: var(--shadow);
    }

    .about-content h2 {
      margin-bottom: 20px;
      font-size: clamp(2.2rem, 5vw, 3.7rem);
    }

    .about-content > p {
      margin-bottom: 28px;
      color: var(--muted);
    }

    .benefits {
      display: grid;
      gap: 16px;
      margin-bottom: 32px;
    }

    .benefit {
      display: flex;
      gap: 14px;
    }

    .benefit-icon {
      display: grid;
      flex: 0 0 42px;
      place-items: center;
      height: 42px;
      background: rgba(143, 171, 120, 0.17);
      border-radius: 13px;
    }

    .benefit h3 {
      margin-bottom: 4px;
      font-size: 1.05rem;
    }

    .benefit p {
      color: var(--muted);
      font-size: 0.94rem;
    }

    /* Menu */
    .menu-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 22px;
    }

    .menu-card {
      padding: 28px;
      background: white;
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: 0 10px 35px rgba(81, 54, 45, 0.06);
      transition: 0.25s ease;
    }

    .menu-card:hover {
      transform: translateY(-6px);
      box-shadow: var(--shadow);
    }

    .menu-card.featured {
      color: white;
      background: var(--brown);
    }

    .menu-card.featured h3,
    .menu-card.featured .menu-price {
      color: white;
    }

    .menu-card.featured .menu-item {
      border-color: rgba(255,255,255,.13);
    }

    .menu-card.featured .menu-description {
      color: rgba(255,255,255,.65);
    }

    .menu-icon {
      display: grid;
      place-items: center;
      width: 58px;
      height: 58px;
      margin-bottom: 20px;
      background: var(--cream);
      border-radius: 18px;
      font-size: 1.8rem;
    }

    .menu-card h3 {
      margin-bottom: 18px;
      font-size: 1.55rem;
    }

    .menu-item {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 5px 12px;
      padding: 15px 0;
      border-bottom: 1px solid var(--border);
    }

    .menu-item:last-child {
      border-bottom: 0;
    }

    .menu-name {
      font-weight: 700;
    }

    .menu-price {
      color: var(--orange-dark);
      font-weight: 700;
    }

    .menu-description {
      grid-column: 1 / -1;
      color: var(--muted);
      font-size: 0.85rem;
    }

    /* Pejsci */
    .dogs {
      background: #f4eadc;
    }

    .dog-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
    }

    .dog-card {
      overflow: hidden;
      background: white;
      border-radius: var(--radius);
      box-shadow: 0 12px 35px rgba(81, 54, 45, 0.08);
    }

    .dog-card img {
      height: 310px;
      object-fit: cover;
      transition: transform 0.4s ease;
    }

    .dog-card:hover img {
      transform: scale(1.04);
    }

    .dog-content {
      padding: 22px;
    }

    .dog-content h3 {
      margin-bottom: 8px;
      font-size: 1.45rem;
    }

    .dog-content p {
      color: var(--muted);
      font-size: 0.94rem;
    }

    .dog-tag {
      display: inline-block;
      margin-top: 14px;
      padding: 7px 11px;
      color: var(--brown);
      background: var(--cream);
      border-radius: 999px;
      font-size: 0.78rem;
      font-weight: 700;
    }

    /* Pravidla */
    .rules-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 18px;
    }

    .rule {
      padding: 26px 22px;
      text-align: center;
      background: white;
      border: 1px solid var(--border);
      border-radius: 20px;
    }

    .rule-number {
      display: grid;
      place-items: center;
      width: 46px;
      height: 46px;
      margin: 0 auto 16px;
      color: white;
      background: var(--orange);
      border-radius: 50%;
      font-family: "Fredoka", sans-serif;
    }

    .rule h3 {
      margin-bottom: 8px;
      font-size: 1.07rem;
    }

    .rule p {
      color: var(--muted);
      font-size: 0.9rem;
    }

    /* Rezervace */
    .booking {
      background: var(--brown);
    }

    .booking-grid {
      display: grid;
      grid-template-columns: 0.85fr 1.15fr;
      align-items: center;
      gap: 70px;
    }

    .booking-copy h2 {
      margin-bottom: 20px;
      color: white;
      font-size: clamp(2.3rem, 5vw, 3.8rem);
    }

    .booking-copy p {
      margin-bottom: 28px;
      color: rgba(255,255,255,.7);
    }

    .contact-list {
      display: grid;
      gap: 15px;
      color: white;
      list-style: none;
    }

    .contact-list li {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .contact-list span {
      display: grid;
      flex: 0 0 38px;
      place-items: center;
      height: 38px;
      background: rgba(255,255,255,.1);
      border-radius: 12px;
    }

    .booking-form {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
      padding: 32px;
      background: white;
      border-radius: 28px;
      box-shadow: var(--shadow);
    }

    .form-group {
      display: grid;
      gap: 7px;
    }

    .form-group.full {
      grid-column: 1 / -1;
    }

    label {
      color: var(--brown-dark);
      font-size: 0.88rem;
      font-weight: 700;
    }

    input,
    select,
    textarea {
      width: 100%;
      min-height: 49px;
      padding: 12px 14px;
      color: var(--text);
      background: var(--cream);
      border: 1px solid var(--border);
      border-radius: 12px;
      outline: none;
      transition: 0.2s ease;
    }

    input:focus,
    select:focus,
    textarea:focus {
      border-color: var(--orange);
      box-shadow: 0 0 0 4px rgba(237, 131, 95, 0.12);
    }

    textarea {
      min-height: 95px;
      resize: vertical;
    }

    .booking-form .btn {
      width: 100%;
      border: 0;
    }

    .form-message {
      display: none;
      grid-column: 1 / -1;
      padding: 12px;
      color: #315c2e;
      background: #e8f5e5;
      border-radius: 12px;
      font-size: 0.9rem;
      font-weight: 600;
    }

    /* Footer */
    .footer {
      padding: 55px 0 28px;
      color: rgba(255,255,255,.7);
      background: var(--brown-dark);
    }

    .footer-grid {
      display: grid;
      grid-template-columns: 1.4fr 0.7fr 0.7fr;
      gap: 50px;
      padding-bottom: 40px;
    }

    .footer .logo {
      margin-bottom: 16px;
      color: white;
    }

    .footer-about {
      max-width: 420px;
    }

    .footer h3 {
      margin-bottom: 15px;
      color: white;
      font-size: 1.05rem;
    }

    .footer-links {
      display: grid;
      gap: 9px;
      list-style: none;
    }

    .footer-links a:hover {
      color: white;
    }

    .copyright {
      display: flex;
      justify-content: space-between;
      gap: 20px;
      padding-top: 25px;
      border-top: 1px solid rgba(255,255,255,.1);
      font-size: 0.86rem;
    }

    @media (max-width: 900px) {
      .nav-links {
        position: absolute;
        top: 78px;
        left: 20px;
        right: 20px;
        display: none;
        flex-direction: column;
        align-items: stretch;
        gap: 8px;
        padding: 20px;
        background: white;
        border: 1px solid var(--border);
        border-radius: 20px;
        box-shadow: var(--shadow);
      }

      .nav-links.open {
        display: flex;
      }

      .nav-links a {
        display: block;
        padding: 10px;
      }

      .menu-button {
        display: block;
      }

      .hero-grid,
      .about-grid,
      .booking-grid {
        grid-template-columns: 1fr;
      }

      .hero {
        padding-top: 55px;
      }

      .hero-content {
        text-align: center;
      }

      .hero-copy {
        margin-inline: auto;
      }

      .hero-actions,
      .hero-note {
        justify-content: center;
      }

      .hero-visual {
        max-width: 590px;
        margin-inline: auto;
      }

      .about-grid,
      .booking-grid {
        gap: 45px;
      }

      .about-images {
        max-width: 620px;
        width: 100%;
        margin-inline: auto;
      }

      .menu-grid,
      .dog-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .menu-card:last-child,
      .dog-card:last-child {
        grid-column: 1 / -1;
      }

      .rules-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 620px) {
      .container {
        width: min(100% - 28px, 1160px);
      }

      .section {
        padding: 75px 0;
      }

      .hero h1 {
        font-size: clamp(3rem, 16vw, 4.7rem);
      }

      .floating-card {
        position: static;
        margin-top: 12px;
        max-width: 100%;
      }

      .stats-grid {
        grid-template-columns: repeat(2, 1fr);
      }

      .stat:nth-child(2) {
        border-right: 0;
      }

      .stat:nth-child(-n+2) {
        border-bottom: 1px solid rgba(255,255,255,.13);
      }

      .about-images {
        min-height: 430px;
      }

      .about-main {
        height: 390px;
      }

      .about-small {
        height: 180px;
      }

      .menu-grid,
      .dog-grid,
      .rules-grid,
      .booking-form,
      .footer-grid {
        grid-template-columns: 1fr;
      }

      .menu-card:last-child,
      .dog-card:last-child {
        grid-column: auto;
      }

      .booking-form {
        padding: 23px;
      }

      .form-group.full {
        grid-column: auto;
      }

      .copyright {
        flex-direction: column;
      }
    }
  </style>
</head>

<body>
  <header class="header">
    <nav class="nav container" aria-label="Hlavní navigace">
      <a href="#uvod" class="logo">
        <span class="logo-mark" aria-hidden="true">🐾</span>
        Psí Kafe
      </a>

      <button class="menu-button" type="button" aria-label="Otevřít menu" aria-expanded="false">
        ☰
      </button>

      <ul class="nav-links">
        <li><a href="#o-nas">O nás</a></li>
        <li><a href="#nabidka">Nabídka</a></li>
        <li><a href="#pejsci">Naši pejsci</a></li>
        <li><a href="#pravidla">Pravidla</a></li>
        <li><a href="#rezervace" class="btn btn-primary">Rezervovat stůl</a></li>
      </ul>
    </nav>
  </header>

  <main>
    <section class="hero" id="uvod">
      <div class="container hero-grid">
        <div class="hero-content">
          <div class="hero-badge">🐶 Všichni pejsci jsou vítáni</div>

          <h1>Káva chutná lépe s <span>chlupáčem.</span></h1>

          <p class="hero-copy">
            Útulná kavárna pro milovníky dobré kávy a psích parťáků.
            Dopřej si domácí dezert, zatímco si tvůj pejsek užívá vlastní menu.
          </p>

          <div class="hero-actions">
            <a href="#rezervace" class="btn btn-primary">Rezervovat návštěvu →</a>
            <a href="#nabidka" class="btn btn-secondary">Prohlédnout menu</a>
          </div>

          <div class="hero-note">
            <span>Výběrová káva</span>
            <span>Psí dobroty</span>
            <span>Bezplatná voda</span>
          </div>
        </div>

        <div class="hero-visual">
          <img
            class="hero-image"
            src="https://images.unsplash.com/photo-1518717758536-85ae29035b6d?auto=format&fit=crop&w=1000&q=85"
            alt="Spokojený pejsek v kavárně"
          >

          <div class="floating-card one">
            <div class="floating-icon">☕</div>
            <div>
              <strong>Čerstvá káva</strong>
              <small>Pražená s láskou</small>
            </div>
          </div>

          <div class="floating-card two">
            <div class="floating-icon">🦴</div>
            <div>
              <strong>Psí menu</strong>
              <small>Od 39 Kč</small>
            </div>
          </div>
        </div>
